generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  administrador
  director_comercial
  comercial
  tecnico
  facturacion
  logistica
}

enum OpportunityStage {
  prospecto
  contacto
  visita
  cotizacion
  negociacion
  orden_facturacion
  venta_cerrada
  perdida
}

enum QuoteStatus {
  abierta
  en_negociacion
  cerrada
  perdida
}

enum OrderStatus {
  recibido
  orden_facturacion
  facturado
  despachado
  entregado
}

enum BillingRequestStatus {
  pendiente
  procesada
  rechazada
}

enum VisitStatus {
  programada
  completada
  cancelada
  no_realizada
}

enum FollowUpTaskStatus {
  pendiente
  completada
  vencida
}

enum FollowUpTaskType {
  llamada
  email
  whatsapp
  reunion
  recordatorio
  otro
}

enum LauraMessageRole {
  user
  assistant
  system
}

enum LauraMessageKind {
  report
  agenda_query
  clarification
  proposal
}

enum LauraProposalStatus {
  draft
  confirmed
  discarded
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedCustomers Customer[] @relation("CustomerAssignedUser")
  assignedOrders Order[]
  createdReports ExecutiveReport[]
  lauraSessions LauraSession[]
}

model LauraSession {
  id              String         @id @default(cuid())
  ownerUserId     String
  contextType     String?
  contextEntityId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  ownerUser       User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  messages        LauraMessage[]
  proposals       LauraProposal[]
}

model LauraMessage {
  id        String           @id @default(cuid())
  sessionId String
  role      LauraMessageRole
  kind      LauraMessageKind
  content   String
  payload   Json?
  createdAt DateTime         @default(now())
  session   LauraSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  proposals LauraProposal[]
}

model LauraProposal {
  id        String               @id @default(cuid())
  sessionId String
  messageId String
  status    LauraProposalStatus  @default(draft)
  payload   Json
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  message   LauraMessage         @relation(fields: [messageId], references: [id], onDelete: Cascade)
  session   LauraSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  previousState Json?
  nextState     Json?
  actorUserId   String
  createdAt     DateTime @default(now())
}

model CustomerSegment {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  createdBy   String
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customers   Customer[]
}

model Customer {
  id               String    @id @default(cuid())
  legalName        String
  displayName      String
  taxId            String?   @unique
  phone            String?
  email            String?
  address          String?
  city             String?
  department       String?
  notes            String?
  segmentId        String
  assignedToUserId String?
  active           Boolean   @default(true)
  createdBy        String
  updatedBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  segment          CustomerSegment @relation(fields: [segmentId], references: [id])
  assignedToUser   User?     @relation("CustomerAssignedUser", fields: [assignedToUserId], references: [id])
  contacts         Contact[]
  opportunities    Opportunity[]
  quotes           Quote[]
  visits           Visit[]
  followUpTasks    FollowUpTask[]
  orders           Order[]
  billingRequests  BillingRequest[]
  reports          ExecutiveReport[]
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  fullName   String
  roleTitle  String?
  phone      String?
  email      String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdBy  String
  updatedBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Opportunity {
  id             String           @id @default(cuid())
  customerId     String
  title          String
  description    String?
  stage          OpportunityStage
  estimatedValue Decimal?         @db.Decimal(14, 2)
  expectedCloseDate DateTime?
  assignedToUserId String?
  lostReason     String?
  closedAt       DateTime?
  createdBy      String
  updatedBy      String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  customer       Customer         @relation(fields: [customerId], references: [id])
  quotes         Quote[]
  visits         Visit[]
  followUpTasks  FollowUpTask[]
  orders         Order[]
  billingRequests BillingRequest[]
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  unit        String
  presentation String?
  basePrice   Decimal  @db.Decimal(14, 2)
  active      Boolean  @default(true)
  createdBy   String
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  quoteItems  QuoteItem[]
  orderItems  OrderItem[]
}

model Quote {
  id            String      @id @default(cuid())
  customerId    String
  opportunityId String?
  status        QuoteStatus @default(abierta)
  validUntil    DateTime?
  notes         String?
  subtotal      Decimal     @db.Decimal(14, 2)
  total         Decimal     @db.Decimal(14, 2)
  createdBy     String
  updatedBy     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  customer      Customer    @relation(fields: [customerId], references: [id])
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  items         QuoteItem[]
  sourceOrders  Order[]
  billingRequests BillingRequest[]
}

model QuoteItem {
  id                  String  @id @default(cuid())
  quoteId             String
  productId           String?
  productSnapshotName String
  productSnapshotSku  String
  unit                String
  quantity            Decimal @db.Decimal(14, 4)
  unitPrice           Decimal @db.Decimal(14, 2)
  subtotal            Decimal @db.Decimal(14, 2)
  notes               String?
  quote               Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id])
}

model Visit {
  id             String      @id @default(cuid())
  customerId     String
  opportunityId  String?
  scheduledAt    DateTime
  completedAt    DateTime?
  status         VisitStatus @default(programada)
  summary        String?
  notes          String?
  nextStep       String?
  assignedToUserId String?
  createdBy      String
  updatedBy      String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  customer       Customer    @relation(fields: [customerId], references: [id])
  opportunity    Opportunity? @relation(fields: [opportunityId], references: [id])
  reports        ExecutiveReport[]
}

model FollowUpTask {
  id             String             @id @default(cuid())
  customerId     String
  opportunityId  String?
  type           FollowUpTaskType
  title          String
  dueAt          DateTime
  status         FollowUpTaskStatus @default(pendiente)
  notes          String?
  assignedToUserId String?
  completedAt    DateTime?
  createdBy      String
  updatedBy      String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  customer       Customer           @relation(fields: [customerId], references: [id])
  opportunity    Opportunity?        @relation(fields: [opportunityId], references: [id])
}

model Order {
  id                  String      @id @default(cuid())
  customerId          String
  opportunityId       String?
  sourceQuoteId       String?
  status              OrderStatus @default(recibido)
  requestedDeliveryDate DateTime?
  assignedLogisticsUserId String?
  committedDeliveryDate DateTime?
  dispatchDate        DateTime?
  deliveryDate        DateTime?
  logisticsNotes      String?
  notes               String?
  subtotal            Decimal     @db.Decimal(14, 2)
  total               Decimal     @db.Decimal(14, 2)
  createdBy           String
  updatedBy           String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  customer            Customer    @relation(fields: [customerId], references: [id])
  opportunity         Opportunity? @relation(fields: [opportunityId], references: [id])
  sourceQuote         Quote?      @relation(fields: [sourceQuoteId], references: [id])
  assignedLogisticsUser User?     @relation(fields: [assignedLogisticsUserId], references: [id])
  items               OrderItem[]
  billingRequests     BillingRequest[]
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  productId           String?
  productSnapshotName String
  productSnapshotSku  String
  unit                String
  quantity            Decimal  @db.Decimal(14, 4)
  unitPrice           Decimal  @db.Decimal(14, 2)
  subtotal            Decimal  @db.Decimal(14, 2)
  notes               String?
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id])
}

model ExecutiveReport {
  id        String   @id @default(cuid())
  title     String
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id])
  visitId   String?
  visit     Visit?   @relation(fields: [visitId], references: [id])
  payload   Json
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  creator   User     @relation(fields: [createdBy], references: [id])
}

model BillingRequest {
  id                String                 @id @default(cuid())
  customerId        String
  opportunityId     String?
  sourceType        String
  sourceQuoteId     String?
  sourceOrderId     String?
  status            BillingRequestStatus   @default(pendiente)
  notes             String?
  requestedByUserId String
  createdBy         String
  updatedBy         String
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  customer          Customer               @relation(fields: [customerId], references: [id])
  opportunity       Opportunity?            @relation(fields: [opportunityId], references: [id])
  sourceQuote       Quote?                  @relation(fields: [sourceQuoteId], references: [id])
  sourceOrder       Order?                  @relation(fields: [sourceOrderId], references: [id])
}
